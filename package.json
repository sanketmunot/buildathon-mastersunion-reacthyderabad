{
  "name": "buildathon-mastersunion-reacthyderabad",
  "version": "1.0.0",
  "description": "Slack-native AI knowledge base assistant MVP",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "reset:data": "node -e \"const fs=require('fs');const paths=['data','storage/uploads'];for(const p of paths){fs.rmSync(p,{recursive:true,force:true});}fs.mkdirSync('storage/uploads',{recursive:true});fs.writeFileSync('storage/uploads/.gitkeep','');console.log('Cleared LanceDB and storage uploads');\""
  },
  "keywords": [
    "slack",
    "rag",
    "knowledge-base"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.19.1",
    "@langchain/community": "^0.3.36",
    "@langchain/core": "^0.3.66",
    "@langchain/groq": "^0.1.3",
    "@langchain/langgraph": "^0.2.39",
    "@langchain/ollama": "^0.2.0",
    "@slack/bolt": "^4.2.0",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  }
}
